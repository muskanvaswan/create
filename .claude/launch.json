{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "dev-setup-password",
      "runtimeExecutable": "env",
      "runtimeArgs": ["SETUP_PASSWORD=test-secret-123", "npm", "run", "dev"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "dev-github-store",
      "runtimeExecutable": "env",
      "runtimeArgs": [
        "AUTH_SECRET=testsecret123",
        "SETUP_PASSWORD=test-secret-123",
        "GITHUB_REPO=owner/repo",
        "GITHUB_TOKEN=fake-token",
        "GITHUB_API_URL=http://127.0.0.1:4599",
        "npm",
        "run",
        "dev"
      ],
      "port": 3000,
      "autoPort": true
    }
  ]
}
