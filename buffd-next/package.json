{
  "name": "@buffd/next",
  "version": "0.1.0",
  "description": "Drop-in friction analytics for Next.js — capture real user friction signals (rage/dead clicks, scroll depth, errors, web vitals) and explore them on a built-in dashboard.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "keywords": ["nextjs", "analytics", "ux", "friction", "rage-click", "web-vitals"],
  "files": ["dist", "DATABASE.md", "README.md"],
  "bin": {
    "buffd": "./bin/init.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    },
    "./route": {
      "types": "./dist/route.d.ts",
      "default": "./dist/route.js"
    },
    "./proxy": {
      "types": "./dist/proxy.d.ts",
      "default": "./dist/proxy.js"
    },
    "./dashboard": {
      "types": "./dist/dashboard/index.d.ts",
      "default": "./dist/dashboard/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "peerDependencies": {
    "next": ">=15",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "optionalDependencies": {
    "pg": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "pg": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.14.8",
    "@types/pg": "^8.11.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "next": "^16",
    "react": "^19",
    "react-dom": "^19",
    "typescript": "^5.5.2"
  }
}
